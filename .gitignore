# --- large, regenerable data (fetched by data/fetch_data.sh; see PROVENANCE.md) ---
data/raw/
!data/raw/.gitkeep

# --- per-run experiment outputs (regenerated by code/scripts/*.py; 80MB+) ---
results/raw/
results/logs/

# --- environments, binaries, caches ---
.venv/
venv/
# 48MB LaTeX engine; install per README instead of committing it
tectonic_bin
tectonic_bin.exe
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# --- LaTeX build artefacts (keep the .tex, .bib, and compiled .pdf) ---
paper/*.aux
paper/*.log
paper/*.out
paper/*.blg
paper/*.bbl
paper/*.fdb_latexmk
paper/*.fls
paper/*.xdv
paper/*.synctex.gz

# --- internal working files (not part of the published artefact) ---
HANDOFF.md
resume.command
resume.sh

# --- OS / editor cruft ---
.DS_Store
*.swp
*~
.vscode/
.idea/

# Kept in-repo for browsability without a full rerun:
#   results/tables/  (small CSV + .tex)
#   results/figures/ (PDF + PNG)
#   paper/main_ieee.pdf  (compiled paper)
